{
  "name": "dom-harness",
  "version": "1.0.0",
  "description": "DOM component test harness library inspired by Angular CDK's ComponentHarness",
  "keywords": [
    "testing",
    "harness",
    "component",
    "dom",
    "test-utils"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koorchik/dom-harness.git"
  },
  "bugs": {
    "url": "https://github.com/koorchik/dom-harness/issues"
  },
  "homepage": "https://github.com/koorchik/dom-harness#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@testing-library/user-event": ">=14.0.0"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
